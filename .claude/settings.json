{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python -m pytest*)",
      "Bash(python src/main.py*)",
      "Bash(pip install*)",
      "Bash(pip freeze*)",
      "Bash(playwright install*)",
      "Bash(git commit *)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(mkdir*)",
      "Bash(touch*)",
      "Bash(ls*)"
    ],
    "deny": [
      "Read(keys/*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
